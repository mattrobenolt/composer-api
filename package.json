{
  "name": "composer-api",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "OpenAI-compatible Chat Completions and Responses API proxy for Cursor Composer.",
  "scripts": {
    "dev": "wrangler dev",
    "sdk:responses": "node scripts/cursor-sdk-responses-proxy.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "deploy": "wrangler deploy"
  },
  "keywords": [
    "cursor",
    "composer",
    "openai",
    "chat-completions",
    "responses-api",
    "cloudflare-workers"
  ],
  "license": "MIT",
  "dependencies": {
    "@cursor/sdk": "^1.0.13"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260520.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15",
    "wrangler": "^4.93.0"
  }
}
